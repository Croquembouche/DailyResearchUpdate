# Local server
PORT=3000
HOST=127.0.0.1

# Daily schedule. America/New_York handles EST/EDT automatically.
CRON_SCHEDULE=0 6 * * *
CRON_TIMEZONE=America/New_York

# arXiv ingestion
ARXIV_MAX_RESULTS=8
ARXIV_LOOKBACK_DAYS=3

# Codex CLI summarization. Override if your local CLI syntax changes.
CODEX_BIN=codex
CODEX_MODEL=gpt-5.5
CODEX_MAX_PAPERS=5
CODEX_TIMEOUT_MS=60000
